.lst-kix_list_1-3 > li::before { content: "" counter(lst-ctn-kix_list_1-3) ". "; }

.lst-kix_list_1-4 > li::before { content: "" counter(lst-ctn-kix_list_1-4, lower-latin) ". "; }

.lst-kix_list_1-0 > li { counter-increment: lst-ctn-kix_list_1-0 1; }

.lst-kix_list_1-6 > li { counter-increment: lst-ctn-kix_list_1-6 1; }

.lst-kix_list_1-7 > li::before { content: "" counter(lst-ctn-kix_list_1-7, lower-latin) ". "; }

.lst-kix_list_1-3 > li { counter-increment: lst-ctn-kix_list_1-3 1; }

.lst-kix_list_1-5 > li::before { content: "" counter(lst-ctn-kix_list_1-5, lower-roman) ". "; }

.lst-kix_list_1-6 > li::before { content: "" counter(lst-ctn-kix_list_1-6) ". "; }

.lst-kix_list_2-0 > li::before { content: "-  "; }

.lst-kix_list_2-1 > li::before { content: "o  "; }

ol.lst-kix_list_6-0.start { counter-reset: lst-ctn-kix_list_6-0 0; }

.lst-kix_list_1-8 > li::before { content: "" counter(lst-ctn-kix_list_1-8, lower-roman) ". "; }

.lst-kix_list_2-2 > li::before { content: "Ō¢¬  "; }

.lst-kix_list_2-3 > li::before { content: "ŌŚÅ  "; }
