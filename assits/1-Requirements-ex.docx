------MultipartBoundary--f8x0lxSRK0nVb6SAU7WocYyWr7b8Cv81TFT3cQYqv3----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: cid:css-8f01f4cc-86fb-4000-afb7-374ac079977b@mhtml.blink

@charset "utf-8";

.docs-ml-promotion { z-index: 1002; }

.docs-ml-header { z-index: 1; }

.docs-ml-icon { direction: ltr; display: inline-block; text-align: left; overflow: hidden; position: relative; vertical-align: middle; }

.docs-ml-img::before { content: url("https://ssl.gstatic.com/docs/common/mobileweb_sprite1.png"); }

.docs-ml-img-container { height: 156px; position: absolute; width: 36px; }

.docs-ml-docs-logo-icon { left: 0px; top: -36px; }

.docs-ml-sheets-logo-icon { left: 0px; top: 0px; }

.docs-ml-slides-logo-icon { left: 0px; top: -96px; }

.docs-ml-arrow-back-icon { left: 0px; top: -132px; }

.docs-ml-edit-icon { left: 0px; top: -72px; }

@media screen and (-webkit-min-device-pixel-ratio: 2) {
  .docs-ml-img { content: url("https://ssl.gstatic.com/docs/common/mobileweb_sprite1.png"); }
  .docs-ml-img-container { height: 156px; position: absolute; width: 36px; }
  .docs-ml-docs-logo-icon { left: 0px; top: -36px; }
  .docs-ml-sheets-logo-icon { left: 0px; top: 0px; }
  .docs-ml-slides-logo-icon { left: 0px; top: -96px; }
  .docs-ml-arrow-back-icon { left: 0px; top: -132px; }
  .docs-ml-edit-icon { left: 0px; top: -72px; }
}

.docs-ml-promotion { background: var(--gm3-sys-color-surface,#fff); bottom: 0px; box-shadow: 0 4px 12px color-mix(in sRGB,var(--gm3-sys-color-shadow,#000) 40%,transparent); font-family: Arial, Helvetica, sans-serif; right: 0px; position: fixed; width: 100%; }

.docs-ml-promotion-off-screen { transform: translateY(100%); }

.docs-ml-promotion-shown { transform: translateY(0px); transition: transform 333ms cubic-bezier(0.4, 0, 0.2, 1); }

.docs-ml-promotion-dismissed { transform: translateY(100%); box-shadow: none; }

.docs-ml-promotion-no-horizontal-scroll { overflow-x: hidden; }

.docs-ml-promotion-header { display: table; padding: 24px 24px 0px; }

.docs-ml-promotion-app-icon-container { display: table-cell; }

.docs-ml-promotion-app-icon { height: 36px; width: 36px; }

@media (min-width: 600px) {
  .docs-ml-promotion-app-icon { transform: scale(1.33); }
}

.docs-ml-promotion-text { display: table-cell; padding-right: 20px; vertical-align: top; }

.docs-ml-promotion-text-heading { color: var(--gm3-sys-color-on-surface,#1f1f1f); font-size: 16px; font-weight: 700; padding-bottom: 7px; }

.docs-ml-promotion-text-body { color: var(--gm3-sys-color-on-surface,#1f1f1f); font-size: 14px; }

.docs-ml-promotion-action-row { float: left; margin-top: 6px; padding: 8px 24px; }

.docs-ml-promotion-action-row-desktop { margin-top: 6px; }

.docs-ml-promotion-action-container { display: inline-block; height: 48px; margin: 6px 4px; vertical-align: middle; }

.docs-ml-promotion-action-button { display: inline-block; font-size: 14px; font-weight: 500; padding: 9px 12px; vertical-align: middle; }

.docs-ml-promotion-action-button-wrapper:focus { outline-color: var(--gm3-sys-color-outline-variant,#c4c7c5); }

.docs-ml-promotion-action-button.docs-ml-promotion-yes-button { background-color: var(--gm3-sys-color-primary,#0b57d0); border-radius: 4px; color: var(--gm3-sys-color-on-primary,#fff); border: 1px solid transparent; }

.docs-ml-promotion-action-button.docs-ml-promotion-yes-button:active { background-color: color-mix(in srgb,var(--gm3-sys-color-on-primary,#fff) 10%,var(--gm3-sys-color-primary,#0b57d0)); }

.docs-ml-promotion-action-button.docs-ml-promotion-no-button { background-color: var(--gm3-sys-color-surface-container-low,#f8fafd); color: var(--gm3-sys-color-on-surface-variant,#444746); border-radius: 4px; border: 1px solid var(--gm3-sys-color-outline-variant,#c4c7c5); }

.docs-ml-promotion-action-button.docs-ml-promotion-no-button:active { background-color: color-mix(in srgb,var(--gm3-sys-color-on-surface,#1f1f1f) 10%,var(--gm3-sys-color-surface-container-low,#f8fafd)); }

.docs-ml-promotion.desktop { text-align: center; }

@media (orientation: portrait) {
  .docs-ml-promotion.desktop { padding-top: 56px; padding-bottom: 80px; }
}

@media (orientation: landscape) {
  .docs-ml-promotion.desktop { padding-top: 36px; padding-bottom: 56px; }
}

.docs-ml-promotion-heading-desktop { font-family: "Google Sans"; font-size: 18px; font-weight: 700; color: var(--gm3-sys-color-on-surface,#1f1f1f); padding-top: 18px; padding-bottom: 10px; line-height: 1.5; max-width: 360px; margin: 0px auto; }

@media (orientation: landscape) {
  .docs-ml-promotion-heading-desktop { padding-top: 0px; max-width: none; }
}

.docs-ml-promotion-text-body-desktop { font-size: 14px; line-height: 1.5; color: var(--gm3-sys-color-on-surface-variant,#444746); padding-bottom: 10px; }

.docs-icon.docs-ml-promotion-desktop-icon { height: 40px; width: 40px; transform: scale(2.5); transform-origin: center top; }

.docs-icon-ml-promotion-icon-container-desktop { height: 100px; width: 100px; margin-right: auto; margin-left: auto; }

@media (orientation: landscape) {
  .docs-icon-ml-promotion-icon-container-desktop { display: inline-block; vertical-align: top; }
  .docs-ml-promotion-description-desktop { display: inline-block; vertical-align: top; text-align: right; padding-right: 39px; max-width: 645px; }
}

@media (orientation: landscape) {
  .docs-ml-promotion-action-row-desktop { margin-right: -8px; }
}

.docs-ml-promotion-action-row-desktop .docs-ml-promotion-action-container { margin: 6px 8px; font-family: "Google Sans"; }

.docs-ml-promotion-action-row-desktop .docs-ml-promotion-action-button-wrapper:focus { outline: none; }

.docs-ml-promotion-action-button.docs-ml-promotion-yes-button.docs-ml-promotion-app-themed { border-radius: 4px; box-shadow: none; box-sizing: border-box; font-family: "Google Sans", Roboto, RobotoDraft, Helvetica, Arial, sans-serif; font-weight: 500; font-size: 14px; height: 36px; letter-spacing: 0.25px; line-height: 16px; padding: 9px 24px 11px; background: var(--gm3-sys-color-primary,#0b57d0); color: var(--gm3-sys-color-on-primary,#fff); border: 1px solid transparent !important; }

.docs-ml-promotion-action-button.docs-ml-promotion-no-button.docs-ml-promotion-app-themed { border-radius: 4px; box-shadow: none; box-sizing: border-box; font-family: "Google Sans", Roboto, RobotoDraft, Helvetica, Arial, sans-serif; font-weight: 500; font-size: 14px; height: 36px; letter-spacing: 0.25px; line-height: 16px; padding: 9px 24px 11px; background: var(--gm3-sys-color-surface,#fff); color: var(--gm3-sys-color-primary,#0b57d0); border: 1px solid var(--gm3-sys-color-outline-variant,#c4c7c5) !important; }

.docs-ml-promotion-action-button-wrapper:focus .docs-ml-promotion-action-button.docs-ml-promotion-yes-button.docs-ml-promotion-app-themed { color: var(--gm3-sys-color-on-primary,#fff); background: linear-gradient(rgba(var(--gm3-sys-color-on-primary-rgb,255,255,255),.1),rgba(var(--gm3-sys-color-on-primary-rgb,255,255,255),.1)),var(--gm3-sys-color-primary,#0b57d0); box-shadow: 0 1px 3px 1px rgba(var(--gm3-sys-color-primary-rgb,11,87,208),.15); }

.docs-ml-promotion-action-button-wrapper:focus .docs-ml-promotion-action-button.docs-ml-promotion-no-button.docs-ml-promotion-app-themed { border-radius: 4px; box-shadow: none; box-sizing: border-box; font-family: "Google Sans", Roboto, RobotoDraft, Helvetica, Arial, sans-serif; font-weight: 500; font-size: 14px; height: 36px; letter-spacing: 0.25px; line-height: 16px; padding: 9px 24px 11px; background: linear-gradient(rgba(var(--gm3-sys-color-on-primary-container-rgb,8,66,160),.1),rgba(var(--gm3-sys-color-on-primary-container-rgb,8,66,160),.1)),var(--gm3-sys-color-primary-container,#d3e3fd); border: 1px solid var(--gm3-sys-color-primary-container,#d3e3fd) !important; }

.docsshared-no-download .docsshared-no-select-when-no-download, .docsshared-no-select { -webkit-user-drag: none; user-select: none; }

.docsshared-disable-image-copy canvas, .docsshared-disable-image-copy image, .docsshared-disable-image-copy img { pointer-events: none; }
