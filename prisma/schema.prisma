generator client {
  provider     = "prisma-client"
  output       = "../generated/prisma"
  moduleFormat = "cjs"
}

datasource db {
  provider = "postgresql"
}

model User {
  id               String           @id @default(uuid())
  name             String
  email            String           @unique
  password         String
  role             Role             @default(user)
  Avatar           String?
  age              Int?
  PhoneNumber      String?
  address          String?
  active           Boolean          @default(true)
  VerificationCode String?
  gender           Gender?
  requast          RequestProduct[]
  CreatedAt        DateTime         @default(now())
  updatedAt        DateTime         @updatedAt
}

enum Role {
  admin
  user
}

enum Gender {
  male
  female
}

model Category {
  id            String        @id @default(uuid())
  name          String        @unique
  image         String
  subCategories subCategory[]
  CreatedAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt
}

model subCategory {
  id         String    @id @default(uuid())
  name       String    @unique
  category   Category? @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  categoryId String?
  CreatedAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model Brand {
  id        String   @id @default(uuid())
  name      String   @unique
  image     String
  CreatedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Coupon {
  id         String   @id @default(uuid())
  name       String   @unique
  expireDate DateTime
  discount   Int
  CreatedAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Sublier {
  id        String   @id @default(uuid())
  name      String   @unique
  website   DateTime
  CreatedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model RequestProduct {
  id        String  @id @default(uuid())
  titleNeed String
  detailes  String
  qauntity  Int?
  category  String?

  user   User?   @relation(fields: [userId], references: [id])
  userId String?

  CreatedAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
